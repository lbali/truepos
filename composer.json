{
    "name": "truepos/truepos",
    "description": "Unified Turkish virtual POS gateway package for Laravel — all banks, one API.",
    "keywords": ["laravel", "payment", "pos", "turkey", "sanal-pos", "nestpay", "garanti", "yapikredi", "3d-secure", "ödeme"],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Levent Bali",
            "email": "leventbali@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-simplexml": "*",
        "ext-dom": "*",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/routing": "^11.0|^12.0",
        "illuminate/events": "^11.0|^12.0",
        "illuminate/cache": "^11.0|^12.0",
        "psr/http-client": "^1.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "laravel/pint": "^1.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "TruePos\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TruePos\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse",
        "lint": "pint",
        "check": [
            "@lint",
            "@analyse",
            "@test"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "TruePos\\Providers\\TruePosServiceProvider"
            ],
            "aliases": {
                "TruePos": "TruePos\\Facades\\TruePos"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
